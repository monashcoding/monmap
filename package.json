{
  "name": "monmap",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "tsx src/index.ts",
    "scrape:all": "tsx src/index.ts --all-years",
    "typecheck": "tsc --noEmit",
    "package": "tar -czf monmap-handbook-$(date +%Y%m%d).tar.gz -C data raw manifest.json && ls -lh monmap-handbook-*.tar.gz"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
